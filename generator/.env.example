# Android NDK Configuration
# Required: Path to your Android NDK installation
# Example: /home/username/android/android-ndk-r27d or /Users/username/Library/Android/sdk/ndk/27.0.12077973
NDK_HOME=/path/to/android-ndk

# Optional: NDK host platform tag (default: linux-x86_64)
# Options: linux-x86_64, darwin-x86_64, darwin-arm64, windows-x86_64
# NDK_HOST_TAG=linux-x86_64

# Optional: Android target architecture (default: aarch64-linux-android)
# Options: aarch64-linux-android, armv7-linux-androideabi, i686-linux-android, x86_64-linux-android
# ANDROID_TARGET_ARCH=aarch64-linux-android

# Optional: Android API level (default: 35)
# ANDROID_API_LEVEL=35

# Required for copy_android_lib.sh: Destination path for the compiled library
# This should point to your passport-reader Android app's JNI libs directory
# Example: /home/username/projects/passport-reader/app/src/main/jniLibs/arm64-v8a
ANDROID_JNILIBS_DEST=/path/to/passport-reader/app/src/main/jniLibs/arm64-v8a


# Passport data in HEX format
EFSOD_HEX=HEX_ENCODED_EF_SOD
DG1_HEX=HEX_ENCODED_DG1